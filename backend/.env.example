# Flask配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/forex_trading
REDIS_URL=redis://localhost:6379/0

# MT5配置
MT5_TIMEOUT=30
MT5_ACCOUNT=your-mt5-account
MT5_PASSWORD=your-mt5-password
MT5_SERVER=your-mt5-server

# WebSocket配置
WS_HOST=0.0.0.0
WS_PORT=5001

# 交易配置
MAX_POSITIONS=100
RISK_PERCENTAGE=2.0

# 缓存配置
CACHE_TTL=300
MARKET_DATA_TTL=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log

# CORS配置
# CORS_ORIGINS环境变量在Python中需要特殊处理，建议在config.py中直接修改